% --- Variables
\newcommand{\titulo}[1]%
  {\newcommand\@titulo{#1}}

\newcommand{\carrera}[1]%
  {\newcommand\@carrera{#1}}
  
\newcommand{\titulocarrera}[1]%
  {\newcommand\@titulocarrera{#1}}
  
\newcommand{\autor}[1]%
  {\newcommand\@autor{#1}}

\newcommand{\tutor}[1]%
  {\newcommand\@tutor{#1}}
  
\newcommand{\fecha}[1]%
  {\newcommand\@fecha{#1}}
  
\newcommand{\fechaC}[1]%
  {\newcommand\@fechaC{#1}}
  
\newcommand{\area}[1]%
  {\newcommand\@area{#1}}

% --- Portadilla
\newcommand\portadilla{%
    \thispagestyle{empty}
    \begin{center}\large
		\includegraphics[width=4.5cm]{Figuras/logoPUCE-04-a}\\[2\baselineskip]
		%
        {\textbf{PONTIFICIA UNIVERSIDAD CATÓLICA DEL ECUADOR}}
        \\[2\baselineskip]
        %
        {\textbf{FACULTAD DE CIENCIAS EXACTAS NATURALES Y AMBIENTALES}}
        \\[2\baselineskip]
        %
        {\textbf{CARRERA DE \MakeTextUppercase\@carrera}}
        \\[3\baselineskip]
        %
        \textbf{\@titulo}\\[3\baselineskip]
        \textbf{Monografía previa a la obtención del título de \@titulocarrera}
        \\[3\baselineskip]
        %
        \textbf{\@autor}\\[3\baselineskip]
        %
        \textbf{Quito, \@fecha}
    \end{center}
    \vspace*{\fill}
    \newpage
}

% --- Certificación
\newcommand{\certificacion}{
    \vspace*{7.46cm}\noindent
    Certifico que la Monografía de \@carrera{} de \textbf{\@autor{}} ha sido concluida de conformidad con las normas establecidas; por lo tanto, puede ser presentada para la calificación correspondiente.

    \vspace{2cm}
    \begin{center}
        \settowidth{\unitlength}{\@tutor}
        \rule{\unitlength}{0.5pt}\\
        \@tutor\\
        Tutor de la monografía\\
        Quito, \@fechaC
    \end{center}
    \newpage
}
% --- Dedicatoria
\newenvironment{dedicatoria}{
    %\thispagestyle{empty}
    \vspace*{\stretch{1}}
    \begin{raggedleft}
        \textbf{DEDICATORIA}

        \itshape
        \vspace{1\baselineskip}
}
{

    \end{raggedleft}
    \vspace*{\stretch{3}}
    \newpage
}
% --- Agradecimiento
\newenvironment{agradecimiento}{
    %\thispagestyle{empty}
    \chapter*{AGRADECIMIENTOS}

    \vspace{1.5\baselineskip}
}
{
    \newpage
}


